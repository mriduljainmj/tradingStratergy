# Copy this file to .env and fill in your credentials
# .env is gitignored — never commit real secrets

# ── Trading mode ──────────────────────────────────────────────────────────────
# BACKTEST | PAPER | LIVE
APP_MODE=PAPER

# ── Kite Connect credentials ──────────────────────────────────────────────────
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# Optional: set this each morning after Kite login to skip the /auth page
# KITE_ACCESS_TOKEN=your_daily_access_token

# ── Dashboard server ──────────────────────────────────────────────────────────
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8080

# ── Local dev user ────────────────────────────────────────────────────────────
# If set, this user is auto-created on first run (no manual registration needed).
# Leave blank on production / Render (real users register via the web form).
DEFAULT_USER_EMAIL=admin@orb.local
DEFAULT_USER_PASSWORD=changeme123

# ── Auth / Security ───────────────────────────────────────────────────────────
# Used to sign JWT tokens. Default is fine for local dev.
# On Render: set this to a long random string in the Environment settings.
# JWT_SECRET_KEY=orb-dev-secret-change-in-prod

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank for local SQLite (auto-created as trading.db).
# On Render: set to your Neon/Supabase PostgreSQL connection string.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
